<launch>
  
  <node pkg="mavros" type="mavros_node" name="mavros"
        required="true" clear_params="true" output="screen">
    <param name="fcu_url" value="udp://:14540@localhost:14557"/>
    <param name="gcs_url" value=""/>
    <param name="target_system_id" value="1"/>
    <param name="target_component_id" value="1"/>
    <rosparam command="load"
      file="$(find mavros)/launch/px4_config.yaml"/>
  </node>

  <node pkg="drone_delivery" type="offboard_heartbeat.py"
        name="offboard_heartbeat" output="screen"/>
</launch>
