<launch>
  <!-- OctoMap -->
  <include file="$(find drone_delivery)/launch/octomap.launch"/>
  
  <!-- Global Planner -->
  <node pkg="drone_delivery" type="global_planner_node.py" 
        name="global_planner_node" output="screen">
    <param name="entropy_weight" value="0.3"/>
  </node>
</launch>
